---
interface Props { darkHero?: boolean; }
const { darkHero = false } = Astro.props;

const links = [
  { href: '/work',    label: 'Work' },
  { href: '/writing', label: 'Writing' },
  { href: '/about',   label: 'About' },
];
const { pathname } = Astro.url;
---

<header
  class:list={['site-nav', darkHero && 'over-hero']}
  style="position: fixed; top: 0; left: 0; right: 0; z-index: 100;"
>
  <nav style="display: flex; align-items: center; justify-content: space-between; padding: 2.25rem 3rem;">
    <a href="/" class="nav-logo font-display font-light text-xs tracking-[0.28em] uppercase transition-colors duration-700">
      Khoi Tran
    </a>
    <ul style="display: flex; gap: 3rem; list-style: none;">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'nav-link font-display font-light text-xs tracking-[0.22em] uppercase transition-colors duration-700',
              pathname.startsWith(href) ? 'active' : '',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  /* Default state — dark page */
  .site-nav .nav-logo,
  .site-nav .nav-link {
    color: var(--color-muted);
  }
  .site-nav .nav-logo:hover,
  .site-nav .nav-link:hover,
  .site-nav .nav-link.active {
    color: var(--color-ink);
  }

  /* Over dark hero — white text */
  .site-nav.over-hero .nav-logo,
  .site-nav.over-hero .nav-link {
    color: rgba(255, 255, 255, 0.65);
  }
  .site-nav.over-hero .nav-logo:hover,
  .site-nav.over-hero .nav-link:hover,
  .site-nav.over-hero .nav-link.active {
    color: rgba(255, 255, 255, 1);
  }
</style>
