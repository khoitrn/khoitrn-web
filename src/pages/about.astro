---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About" description="Student, founder, and engineer based in Texas.">

  <div class="pt-40 pb-32 px-6 md:px-12">
    <div class="max-w-5xl mx-auto">

      <!-- Header -->
      <div class="mb-24 pb-8 border-b border-[var(--color-border)]">
        <p class="animate-fade-up font-display font-light text-xs tracking-[0.3em] uppercase text-[var(--color-muted)] mb-6">About</p>
        <h1 class="animate-fade-up animate-fade-up-delay-1 font-display font-light leading-[1.1] tracking-[-0.02em] text-[var(--color-ink)]" style="font-size: clamp(2.5rem, 6vw, 4.5rem);">
          Student, founder,<br />engineer.
        </h1>
      </div>

      <!-- Body -->
      <div class="grid md:grid-cols-[1fr_2fr] gap-16 md:gap-24">

        <!-- Photo placeholder -->
        <div class="reveal">
          <div class="aspect-[3/4] bg-[var(--color-surface)] rounded-sm overflow-hidden">
            <!-- Replace with <img src={yourPhoto} alt="Khoi Tran" class="w-full h-full object-cover" /> -->
          </div>
        </div>

        <!-- Text -->
        <div class="reveal space-y-8" style="transition-delay: 120ms;">
          <p class="font-body text-lg text-[var(--color-ink-soft)] leading-relaxed">
            I'm Khoi Tran — a student at Texas A&M University, building things at the intersection of technology, product, and entrepreneurship.
          </p>
          <p class="font-body text-[var(--color-ink-soft)] leading-relaxed">
            I started writing code because I wanted to build things I cared about. That curiosity led me to engineering, then to product thinking, and eventually to starting companies. Each path fed the others.
          </p>
          <p class="font-body text-[var(--color-ink-soft)] leading-relaxed">
            I care deeply about craft — code that's readable, products that are intuitive, and writing that earns its reader's attention. I believe the most important skill in building is knowing what to leave out.
          </p>

          <div class="pt-8 border-t border-[var(--color-border)]">
            <p class="font-display font-light text-xs tracking-[0.3em] uppercase text-[var(--color-muted)] mb-6">Currently</p>
            <ul class="space-y-2 font-body text-[var(--color-ink-soft)]">
              <li>Studying at Texas A&M University</li>
              <li>Building — ask me what's current</li>
              <li>Writing here, thinking out loud</li>
            </ul>
          </div>

          <div class="pt-8 border-t border-[var(--color-border)]">
            <p class="font-display font-light text-xs tracking-[0.3em] uppercase text-[var(--color-muted)] mb-6">Get in touch</p>
            <a
              href="mailto:khoi@tamu.edu"
              class="font-display font-light text-xs tracking-[0.2em] uppercase text-[var(--color-accent)] hover:text-[var(--color-ink)] transition-colors duration-300"
            >
              khoi@tamu.edu →
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

</Layout>
