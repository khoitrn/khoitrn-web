---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About">
  <div style="min-height:100svh; padding:7rem 3rem 8rem;">
    <div style="max-width:1100px; margin:0 auto;">

      <!-- Back -->
      <a href="/" style="font-family:var(--font-display); font-weight:300; font-size:0.65rem; letter-spacing:0.28em; text-transform:uppercase; color:var(--color-muted); text-decoration:none; display:inline-block; margin-bottom:5rem; transition:color 0.4s;" onmouseover="this.style.color='var(--color-ink)'" onmouseout="this.style.color='var(--color-muted)'">khoitrn</a>

      <!-- Header -->
      <div style="margin-bottom:6rem;">
        <p class="animate-fade-up" style="font-family:var(--font-display); font-weight:300; font-size:0.65rem; letter-spacing:0.35em; text-transform:uppercase; color:var(--color-muted); margin-bottom:1.25rem;">About</p>
        <h1 class="animate-fade-up delay-1" style="font-family:var(--font-display); font-weight:300; font-size:clamp(2.75rem,6vw,5rem); line-height:1.05; letter-spacing:-0.025em; color:var(--color-ink);">Student, founder,<br/>engineer.</h1>
      </div>

      <!-- Content grid -->
      <div style="display:grid; grid-template-columns:1fr 2fr; gap:7rem; align-items:start;">

        <!-- Photo -->
        <div class="reveal">
          <div style="aspect-ratio:3/4; background:var(--color-surface); border-radius:2px; overflow:hidden;">
            <!-- <img src="/photo.jpg" alt="Khoi Tran" style="width:100%;height:100%;object-fit:cover;" /> -->
          </div>
        </div>

        <!-- Text -->
        <div class="reveal" style="transition-delay:80ms;">
          <p style="font-family:var(--font-body); font-size:1.125rem; color:var(--color-ink-soft); line-height:1.9; margin-bottom:1.75rem;">
            I'm Khoi Tran — a student at Texas A&M University, building things at the intersection of technology, product, and entrepreneurship.
          </p>
          <p style="font-family:var(--font-body); font-size:1rem; color:var(--color-ink-soft); line-height:1.9; margin-bottom:1.75rem;">
            I started writing code because I wanted to build things I cared about. That curiosity led me to engineering, then to product thinking, and eventually to starting companies.
          </p>
          <p style="font-family:var(--font-body); font-size:1rem; color:var(--color-muted); line-height:1.9; margin-bottom:4rem;">
            I care deeply about craft — code that's readable, products that are intuitive, and writing that earns its reader's attention.
          </p>

          <!-- Currently — slash list -->
          <p style="font-family:var(--font-display); font-weight:300; font-size:0.65rem; letter-spacing:0.35em; text-transform:uppercase; color:var(--color-muted); margin-bottom:1.75rem;">Currently</p>
          <div>
            {['Studying at Texas A&M University', 'Building — ask me what\'s current', 'Writing here, thinking out loud'].map((item, i) => (
              <div style="display:flex; align-items:baseline; gap:1rem; padding:0.9rem 0;">
                {i > 0 && <span style="display:none"></span>}
                <span style="font-family:var(--font-display); font-weight:300; font-size:0.75rem; color:var(--color-border); flex-shrink:0;">{i > 0 ? '/' : ''}</span>
                <span style="font-family:var(--font-body); font-size:0.95rem; color:var(--color-ink-soft); line-height:1.6;">{item}</span>
              </div>
            ))}
          </div>

          <div style="margin-top:4rem; padding-top:3rem; border-top:1px solid var(--color-border);">
            <a href="mailto:khoi@tamu.edu" style="font-family:var(--font-display); font-weight:300; font-size:0.7rem; letter-spacing:0.22em; text-transform:uppercase; color:var(--color-accent); text-decoration:none; transition:color 0.4s;" onmouseover="this.style.color='var(--color-ink)'" onmouseout="this.style.color='var(--color-accent)'">khoi@tamu.edu →</a>
          </div>
        </div>
      </div>

    </div>
  </div>
</Layout>
