---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Get in touch with Khoi Tran.">

  <div class="pt-40 pb-32 px-6 md:px-12">
    <div class="max-w-2xl mx-auto">

      <div class="mb-24 pb-8 border-b border-[var(--color-border)]">
        <p class="animate-fade-up font-display font-light text-xs tracking-[0.3em] uppercase text-[var(--color-muted)] mb-6">Contact</p>
        <h1 class="animate-fade-up animate-fade-up-delay-1 font-display font-light leading-[1.1] tracking-[-0.02em] text-[var(--color-ink)]" style="font-size: clamp(2.5rem, 6vw, 4.5rem);">
          Let's talk.
        </h1>
      </div>

      <div class="reveal space-y-12">
        <p class="font-body text-lg text-[var(--color-ink-soft)] leading-relaxed">
          I'm always open to interesting conversations — whether it's about a project you're building, an idea you're sitting on, or just something worth discussing.
        </p>

        <div class="space-y-6">
          <div class="flex items-baseline gap-8 py-5 border-b border-[var(--color-border)]">
            <span class="font-display font-light text-xs tracking-[0.2em] uppercase text-[var(--color-muted)] w-24 shrink-0">Email</span>
            <a href="mailto:khoi@tamu.edu" class="font-display font-light text-[var(--color-ink)] hover:text-[var(--color-accent)] transition-colors duration-300">
              khoi@tamu.edu
            </a>
          </div>

          <div class="flex items-baseline gap-8 py-5 border-b border-[var(--color-border)]">
            <span class="font-display font-light text-xs tracking-[0.2em] uppercase text-[var(--color-muted)] w-24 shrink-0">GitHub</span>
            <a href="https://github.com/khoitrn" target="_blank" rel="noopener noreferrer" class="font-display font-light text-[var(--color-ink)] hover:text-[var(--color-accent)] transition-colors duration-300">
              @khoitrn
            </a>
          </div>

          <div class="flex items-baseline gap-8 py-5 border-b border-[var(--color-border)]">
            <span class="font-display font-light text-xs tracking-[0.2em] uppercase text-[var(--color-muted)] w-24 shrink-0">LinkedIn</span>
            <a href="https://linkedin.com/in/khoitrn" target="_blank" rel="noopener noreferrer" class="font-display font-light text-[var(--color-ink)] hover:text-[var(--color-accent)] transition-colors duration-300">
              Khoi Tran
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>

</Layout>
