---
import Layout from '../layouts/Layout.astro';
import { client, featuredProjectsQuery, recentPostsQuery, formatDate } from '../lib/sanity';

const [projects, posts] = await Promise.all([
  client.fetch(featuredProjectsQuery),
  client.fetch(recentPostsQuery),
]);
---

<Layout title="Khoi Tran">

  <!-- ── Hero ── -->
  <section class="relative w-full h-screen flex flex-col justify-end overflow-hidden">

    <!-- Atmospheric background -->
    <div class="absolute inset-0 z-0" aria-hidden="true">
      <div class="absolute inset-0 z-10" style="background: linear-gradient(to top, #F9F7F4 0%, rgba(249,247,244,0.5) 40%, rgba(249,247,244,0.1) 100%);"></div>
      <div class="w-full h-full" style="background: radial-gradient(ellipse 120% 80% at 60% 40%, #E8E0D4 0%, #F0ECE4 40%, #F9F7F4 100%);"></div>
    </div>

    <!-- Hero content — pinned to bottom left, generous inset -->
    <div class="relative z-10 w-full" style="padding: 0 3rem 5rem;">
      <p class="animate-fade-up font-display font-light text-xs tracking-[0.35em] uppercase text-[var(--color-muted)] mb-7">
        Student · Founder · Engineer
      </p>
      <h1 class="animate-fade-up delay-1 font-display font-light tracking-[-0.03em] text-[var(--color-ink)] mb-8 leading-[1]" style="font-size: clamp(4.5rem, 10vw, 9rem);">
        Khoi Tran
      </h1>
      <p class="animate-fade-up delay-2 font-body text-lg text-[var(--color-ink-soft)] leading-relaxed" style="max-width: 38ch;">
        I build things and think about building things —
        products, companies, and the ideas that hold them together.
      </p>
    </div>

    <!-- Scroll hint -->
    <div class="animate-fade-up delay-4 absolute bottom-8 right-12 z-10">
      <span class="font-display font-light text-xs tracking-[0.25em] uppercase text-[var(--color-muted)]">Scroll</span>
    </div>
  </section>

  <!-- ── Selected Work ── -->
  <section style="padding: 9rem 3rem;">
    <div style="max-width: 1100px; margin: 0 auto;">

      <div class="reveal flex items-baseline justify-between pb-5 mb-14" style="border-bottom: 1px solid var(--color-border);">
        <span class="font-display font-light text-xs tracking-[0.3em] uppercase text-[var(--color-muted)]">
          Selected Work
        </span>
        <a href="/work" class="font-display font-light text-xs tracking-[0.2em] uppercase text-[var(--color-accent)] hover:text-[var(--color-ink)] transition-colors duration-500">
          All projects →
        </a>
      </div>

      {projects.length > 0 ? (
        <div>
          {projects.map((item: any, i: number) => (
            <a
              href={`/work/${item.slug.current}`}
              class="reveal group flex items-baseline justify-between py-7 transition-all duration-500"
              style={`border-bottom: 1px solid var(--color-border); transition-delay: ${i * 80}ms;`}
            >
              <span class="font-display font-light text-[var(--color-ink)] group-hover:translate-x-3 transition-transform duration-500 ease-out" style="font-size: clamp(1.4rem, 3vw, 2rem);">
                {item.title}
              </span>
              <span class="font-display font-light text-xs tracking-[0.18em] uppercase text-[var(--color-muted)] flex gap-8 shrink-0 ml-8">
                <span>{item.category}</span>
                <span>{item.year}</span>
              </span>
            </a>
          ))}
        </div>
      ) : (
        <p class="font-display font-light text-xs tracking-[0.25em] uppercase text-[var(--color-muted)] py-12">Projects coming soon.</p>
      )}
    </div>
  </section>

  <!-- ── Writing ── -->
  <section style="padding: 9rem 3rem; background: var(--color-surface);">
    <div style="max-width: 1100px; margin: 0 auto;">

      <div class="reveal flex items-baseline justify-between pb-5 mb-14" style="border-bottom: 1px solid var(--color-border);">
        <span class="font-display font-light text-xs tracking-[0.3em] uppercase text-[var(--color-muted)]">
          Writing
        </span>
        <a href="/writing" class="font-display font-light text-xs tracking-[0.2em] uppercase text-[var(--color-accent)] hover:text-[var(--color-ink)] transition-colors duration-500">
          All posts →
        </a>
      </div>

      {posts.length > 0 ? (
        <div>
          {posts.map((post: any, i: number) => (
            <a
              href={`/writing/${post.slug.current}`}
              class="reveal group flex items-baseline justify-between py-7 transition-all duration-500"
              style={`border-bottom: 1px solid var(--color-border); transition-delay: ${i * 80}ms;`}
            >
              <span class="font-display font-light text-[var(--color-ink)] group-hover:translate-x-3 transition-transform duration-500 ease-out" style="font-size: clamp(1.1rem, 2.5vw, 1.6rem); max-width: 60%;">
                {post.title}
              </span>
              <span class="font-display font-light text-xs tracking-[0.18em] uppercase text-[var(--color-muted)] flex gap-8 shrink-0 ml-8">
                <span>{post.category}</span>
                <span>{formatDate(post.publishedAt)}</span>
              </span>
            </a>
          ))}
        </div>
      ) : (
        <p class="font-display font-light text-xs tracking-[0.25em] uppercase text-[var(--color-muted)] py-12">Writing coming soon.</p>
      )}
    </div>
  </section>

  <!-- ── About + Now ── -->
  <section style="padding: 9rem 3rem;">
    <div style="max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 6rem;">

      <div class="reveal">
        <p class="font-display font-light text-xs tracking-[0.3em] uppercase text-[var(--color-muted)] mb-10">About</p>
        <p class="font-body text-lg text-[var(--color-ink-soft)] leading-relaxed mb-6">
          I'm a student and founder based in Texas, building at the intersection of technology and product.
        </p>
        <p class="font-body text-[var(--color-ink-soft)] leading-relaxed mb-12">
          I care about the craft of making — code that's clean, products that are clear, and ideas that have earned their place.
        </p>
        <a href="/about" class="font-display font-light text-xs tracking-[0.2em] uppercase text-[var(--color-accent)] hover:text-[var(--color-ink)] transition-colors duration-500">
          More about me →
        </a>
      </div>

      <div class="reveal" style="transition-delay: 120ms;">
        <p class="font-display font-light text-xs tracking-[0.3em] uppercase text-[var(--color-muted)] mb-10">Now</p>
        <p class="font-body text-[var(--color-ink-soft)] leading-relaxed mb-12">
          Currently focused on building products, writing more, and figuring out what it means to start something from scratch.
        </p>
        <a href="/now" class="font-display font-light text-xs tracking-[0.2em] uppercase text-[var(--color-accent)] hover:text-[var(--color-ink)] transition-colors duration-500">
          What I'm doing now →
        </a>
      </div>

    </div>
  </section>

</Layout>
