---
import Layout from '../layouts/Layout.astro';
import { client, featuredProjectsQuery, recentPostsQuery, formatDate } from '../lib/sanity';

const [projects, posts] = await Promise.all([
  client.fetch(featuredProjectsQuery),
  client.fetch(recentPostsQuery),
]);
---

<Layout title="Khoi Tran" darkHero={true}>

  <!-- ═══════════════════════════════════════
       HERO — Full bleed cinematic landing
       Replace /hero.jpg with your own photo.
       Image should be dark + atmospheric.
  ════════════════════════════════════════════ -->
  <section
    data-hero
    style="
      position: relative;
      width: 100%;
      height: 100svh;
      min-height: 600px;
      background: #0b0a09;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
    "
  >
    <!-- Background — replace with your own photo:
         Add /public/hero.jpg and set background-image: url('/hero.jpg')  -->
    <div
      aria-hidden="true"
      style="
        position: absolute;
        inset: 0;
        background:
          radial-gradient(ellipse 80% 60% at 68% 38%, rgba(58, 42, 28, 0.85) 0%, transparent 65%),
          radial-gradient(ellipse 50% 40% at 20% 70%, rgba(32, 26, 18, 0.7) 0%, transparent 60%),
          radial-gradient(ellipse 100% 80% at 50% 100%, rgba(10, 8, 6, 0.9) 0%, transparent 55%),
          linear-gradient(165deg, #1c1610 0%, #0e0c09 35%, #080705 65%, #030302 100%);
      "
    ></div>
    <!-- Subtle grain texture for depth -->
    <div
      aria-hidden="true"
      style="
        position: absolute;
        inset: 0;
        opacity: 0.04;
        background-image: url(&quot;data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E&quot;);
        background-size: 200px;
      "
    ></div>

    <!-- Gradient vignette for text legibility -->
    <div
      aria-hidden="true"
      style="
        position: absolute;
        inset: 0;
        background: linear-gradient(
          to top,
          rgba(0,0,0,0.72) 0%,
          rgba(0,0,0,0.18) 45%,
          rgba(0,0,0,0.04) 100%
        );
      "
    ></div>

    <!-- Hero text — bottom left, like Tawaraya -->
    <div
      style="
        position: relative;
        z-index: 10;
        padding: 0 3rem 4.5rem;
        max-width: 820px;
      "
    >
      <p
        class="animate-fade-up"
        style="
          font-family: var(--font-display);
          font-weight: 300;
          font-size: 0.7rem;
          letter-spacing: 0.35em;
          text-transform: uppercase;
          color: rgba(255,255,255,0.5);
          margin-bottom: 1.5rem;
        "
      >
        Student · Founder · Engineer
      </p>

      <h1
        class="animate-fade-up delay-1"
        style="
          font-family: var(--font-display);
          font-weight: 300;
          font-size: clamp(3.5rem, 9vw, 8rem);
          line-height: 1;
          letter-spacing: -0.025em;
          color: rgba(255,255,255,0.95);
          margin-bottom: 1.75rem;
        "
      >
        Khoi Tran
      </h1>

      <p
        class="animate-fade-up delay-2"
        style="
          font-family: var(--font-body);
          font-size: clamp(1rem, 1.5vw, 1.125rem);
          line-height: 1.7;
          color: rgba(255,255,255,0.55);
          max-width: 38ch;
        "
      >
        I build things and think about building things —
        products, companies, and the ideas that hold them together.
      </p>
    </div>

    <!-- Scroll hint — bottom right -->
    <div
      class="animate-fade-up delay-4"
      style="
        position: absolute;
        bottom: 2.75rem;
        right: 3rem;
        z-index: 10;
      "
    >
      <span
        style="
          font-family: var(--font-display);
          font-weight: 300;
          font-size: 0.65rem;
          letter-spacing: 0.3em;
          text-transform: uppercase;
          color: rgba(255,255,255,0.35);
        "
      >Scroll</span>
    </div>
  </section>

  <!-- ═══════════════════════════════
       SELECTED WORK
  ════════════════════════════════════ -->
  <section style="padding: 8rem 3rem; background: var(--color-canvas);">
    <div style="max-width: 1100px; margin: 0 auto;">

      <div
        class="reveal"
        style="display: flex; align-items: baseline; justify-content: space-between; padding-bottom: 1.25rem; margin-bottom: 3.5rem; border-bottom: 1px solid var(--color-border);"
      >
        <span style="font-family: var(--font-display); font-weight: 300; font-size: 0.7rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--color-muted);">
          Selected Work
        </span>
        <a
          href="/work"
          style="font-family: var(--font-display); font-weight: 300; font-size: 0.7rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--color-accent); text-decoration: none; transition: color 0.5s;"
          onmouseover="this.style.color='var(--color-ink)'"
          onmouseout="this.style.color='var(--color-accent)'"
        >
          All projects →
        </a>
      </div>

      {projects.length > 0 ? (
        <div>
          {projects.map((item: any, i: number) => (
            <a
              href={`/work/${item.slug.current}`}
              class="reveal work-row"
              style={`display: flex; align-items: baseline; justify-content: space-between; padding: 1.75rem 0; border-bottom: 1px solid var(--color-border); text-decoration: none; transition-delay: ${i * 70}ms;`}
            >
              <span class="work-title" style="font-family: var(--font-display); font-weight: 300; font-size: clamp(1.35rem, 2.8vw, 2rem); color: var(--color-ink); transition: transform 0.5s cubic-bezier(0.16,1,0.3,1);">
                {item.title}
              </span>
              <span style="font-family: var(--font-display); font-weight: 300; font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--color-muted); display: flex; gap: 2.5rem; flex-shrink: 0; margin-left: 2rem;">
                <span>{item.category}</span>
                <span>{item.year}</span>
              </span>
            </a>
          ))}
        </div>
      ) : (
        <p style="font-family: var(--font-display); font-weight: 300; font-size: 0.7rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--color-muted); padding: 3rem 0;">Projects coming soon.</p>
      )}
    </div>
  </section>

  <!-- ═══════════════════════════════
       WRITING
  ════════════════════════════════════ -->
  <section style="padding: 8rem 3rem; background: var(--color-surface);">
    <div style="max-width: 1100px; margin: 0 auto;">

      <div
        class="reveal"
        style="display: flex; align-items: baseline; justify-content: space-between; padding-bottom: 1.25rem; margin-bottom: 3.5rem; border-bottom: 1px solid var(--color-border);"
      >
        <span style="font-family: var(--font-display); font-weight: 300; font-size: 0.7rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--color-muted);">
          Writing
        </span>
        <a
          href="/writing"
          style="font-family: var(--font-display); font-weight: 300; font-size: 0.7rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--color-accent); text-decoration: none; transition: color 0.5s;"
          onmouseover="this.style.color='var(--color-ink)'"
          onmouseout="this.style.color='var(--color-accent)'"
        >
          All posts →
        </a>
      </div>

      {posts.length > 0 ? (
        <div>
          {posts.map((post: any, i: number) => (
            <a
              href={`/writing/${post.slug.current}`}
              class="reveal work-row"
              style={`display: flex; align-items: baseline; justify-content: space-between; padding: 1.75rem 0; border-bottom: 1px solid var(--color-border); text-decoration: none; transition-delay: ${i * 70}ms;`}
            >
              <span class="work-title" style="font-family: var(--font-display); font-weight: 300; font-size: clamp(1.1rem, 2.2vw, 1.6rem); color: var(--color-ink); max-width: 60%; transition: transform 0.5s cubic-bezier(0.16,1,0.3,1);">
                {post.title}
              </span>
              <span style="font-family: var(--font-display); font-weight: 300; font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--color-muted); display: flex; gap: 2.5rem; flex-shrink: 0; margin-left: 2rem;">
                <span>{post.category}</span>
                <span>{formatDate(post.publishedAt)}</span>
              </span>
            </a>
          ))}
        </div>
      ) : (
        <p style="font-family: var(--font-display); font-weight: 300; font-size: 0.7rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--color-muted); padding: 3rem 0;">Writing coming soon.</p>
      )}
    </div>
  </section>

  <!-- ═══════════════════════════════
       ABOUT + NOW
  ════════════════════════════════════ -->
  <section style="padding: 8rem 3rem; background: var(--color-canvas);">
    <div style="max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 6rem;">

      <div class="reveal">
        <p style="font-family: var(--font-display); font-weight: 300; font-size: 0.7rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--color-muted); margin-bottom: 2.5rem;">About</p>
        <p style="font-family: var(--font-body); font-size: 1.125rem; color: var(--color-ink-soft); line-height: 1.8; margin-bottom: 1.25rem;">
          I'm a student and founder based in Texas, building at the intersection of technology and product.
        </p>
        <p style="font-family: var(--font-body); font-size: 1rem; color: var(--color-muted); line-height: 1.8; margin-bottom: 3rem;">
          I care about the craft of making — code that's clean, products that are clear, and ideas that have earned their place.
        </p>
        <a href="/about" style="font-family: var(--font-display); font-weight: 300; font-size: 0.7rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--color-accent); text-decoration: none;">More about me →</a>
      </div>

      <div class="reveal" style="transition-delay: 120ms;">
        <p style="font-family: var(--font-display); font-weight: 300; font-size: 0.7rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--color-muted); margin-bottom: 2.5rem;">Now</p>
        <p style="font-family: var(--font-body); font-size: 1rem; color: var(--color-muted); line-height: 1.8; margin-bottom: 3rem;">
          Currently focused on building products, writing more, and figuring out what it means to start something from scratch.
        </p>
        <a href="/now" style="font-family: var(--font-display); font-weight: 300; font-size: 0.7rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--color-accent); text-decoration: none;">What I'm doing now →</a>
      </div>

    </div>
  </section>

</Layout>

<style>
  .work-row:hover .work-title {
    transform: translateX(10px);
  }
</style>
