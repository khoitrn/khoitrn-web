---
import Layout from '../layouts/Layout.astro';
import { client, featuredProjectsQuery, recentPostsQuery, formatDate } from '../lib/sanity';

const [projects, posts] = await Promise.all([
  client.fetch(featuredProjectsQuery),
  client.fetch(recentPostsQuery),
]);
---

<Layout title="Khoi Tran">

  <!-- Hero -->
  <section class="relative min-h-screen flex items-end pb-20 px-6 md:px-12 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 z-10" style="background: linear-gradient(to top, rgba(249,247,244,0.9) 0%, rgba(249,247,244,0.3) 60%, transparent 100%);"></div>
      <div class="w-full h-full" style="background: linear-gradient(160deg, #EDE8E0 0%, #F9F7F4 60%, #E8E2D9 100%);" aria-hidden="true"></div>
    </div>

    <div class="relative z-10 max-w-5xl w-full mx-auto">
      <p class="animate-fade-up font-display font-light text-xs tracking-[0.3em] uppercase text-[var(--color-muted)] mb-8">
        Student · Founder · Engineer
      </p>
      <h1 class="animate-fade-up animate-fade-up-delay-1 font-display font-light leading-[1.05] tracking-[-0.02em] text-[var(--color-ink)] mb-8" style="font-size: clamp(3rem, 8vw, 6rem);">
        Khoi Tran
      </h1>
      <p class="animate-fade-up animate-fade-up-delay-2 font-body text-lg text-[var(--color-ink-soft)] max-w-md leading-relaxed">
        I build things and think about building things —
        products, companies, and the ideas that hold them together.
      </p>
    </div>
  </section>

  <!-- Selected Work -->
  <section class="py-32 px-6 md:px-12">
    <div class="max-w-5xl mx-auto">
      <div class="reveal flex items-baseline mb-16 pb-4 border-b border-[var(--color-border)]">
        <h2 class="font-display font-light text-xs tracking-[0.3em] uppercase text-[var(--color-muted)]">Selected Work</h2>
        <a href="/work" class="font-display font-light text-xs tracking-[0.2em] uppercase text-[var(--color-accent)] hover:text-[var(--color-ink)] transition-colors duration-300 ml-auto">All projects →</a>
      </div>

      {projects.length > 0 ? (
        <div>
          {projects.map((item: any) => (
            <a href={`/work/${item.slug.current}`} class="reveal group flex items-baseline justify-between py-6 border-b border-[var(--color-border)] hover:border-[var(--color-ink)] transition-all duration-300">
              <span class="font-display font-light text-xl md:text-2xl text-[var(--color-ink)] group-hover:translate-x-2 transition-transform duration-300 ease-out">{item.title}</span>
              <span class="font-display font-light text-xs tracking-[0.15em] uppercase text-[var(--color-muted)] flex gap-6 shrink-0 ml-4">
                <span>{item.category}</span>
                <span>{item.year}</span>
              </span>
            </a>
          ))}
        </div>
      ) : (
        <p class="font-body text-[var(--color-muted)] py-8">Projects coming soon.</p>
      )}
    </div>
  </section>

  <!-- Recent Writing -->
  <section class="py-32 px-6 md:px-12 bg-[var(--color-surface)]">
    <div class="max-w-5xl mx-auto">
      <div class="reveal flex items-baseline mb-16 pb-4 border-b border-[var(--color-border)]">
        <h2 class="font-display font-light text-xs tracking-[0.3em] uppercase text-[var(--color-muted)]">Writing</h2>
        <a href="/writing" class="font-display font-light text-xs tracking-[0.2em] uppercase text-[var(--color-accent)] hover:text-[var(--color-ink)] transition-colors duration-300 ml-auto">All posts →</a>
      </div>

      {posts.length > 0 ? (
        <div>
          {posts.map((post: any) => (
            <a href={`/writing/${post.slug.current}`} class="reveal group flex items-baseline justify-between py-6 border-b border-[var(--color-border)] hover:border-[var(--color-ink)] transition-all duration-300">
              <span class="font-display font-light text-lg md:text-xl text-[var(--color-ink)] group-hover:translate-x-2 transition-transform duration-300 ease-out max-w-sm">{post.title}</span>
              <span class="font-display font-light text-xs tracking-[0.15em] uppercase text-[var(--color-muted)] flex gap-6 shrink-0 ml-4">
                <span>{post.category}</span>
                <span>{formatDate(post.publishedAt)}</span>
              </span>
            </a>
          ))}
        </div>
      ) : (
        <p class="font-body text-[var(--color-muted)] py-8">Writing coming soon.</p>
      )}
    </div>
  </section>

  <!-- About + Now -->
  <section class="py-32 px-6 md:px-12">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-16 items-start">
      <div class="reveal">
        <p class="font-display font-light text-xs tracking-[0.3em] uppercase text-[var(--color-muted)] mb-8">About</p>
        <p class="font-body text-lg text-[var(--color-ink-soft)] leading-relaxed mb-6">
          I'm a student and founder based in Texas, building at the intersection of technology and product.
        </p>
        <p class="font-body text-[var(--color-ink-soft)] leading-relaxed mb-10">
          I care about the craft of making — code that's clean, products that are clear, and ideas that have earned their place.
        </p>
        <a href="/about" class="font-display font-light text-xs tracking-[0.2em] uppercase text-[var(--color-accent)] hover:text-[var(--color-ink)] transition-colors duration-300">More about me →</a>
      </div>

      <div class="reveal" style="transition-delay: 120ms;">
        <p class="font-display font-light text-xs tracking-[0.3em] uppercase text-[var(--color-muted)] mb-8">Now</p>
        <p class="font-body text-[var(--color-ink-soft)] leading-relaxed mb-4">
          Currently focused on building products, writing more, and figuring out what it means to start something from scratch.
        </p>
        <a href="/now" class="font-display font-light text-xs tracking-[0.2em] uppercase text-[var(--color-accent)] hover:text-[var(--color-ink)] transition-colors duration-300">What I'm doing now →</a>
      </div>
    </div>
  </section>

</Layout>
