---
import Layout from '../layouts/Layout.astro';
import { client, featuredProjectsQuery, recentPostsQuery, formatDate } from '../lib/sanity';

const [projects, posts] = await Promise.all([
  client.fetch(featuredProjectsQuery),
  client.fetch(recentPostsQuery),
]);
---

<Layout title="Khoi Tran" hideNav={true}>

  <!-- ═══════════════════════════════════════════════════
    HERO SCROLL ZONE
    200svh tall — hero sticks for the first 100svh of scroll.
    Rectangle zooms out as user scrolls, then content is revealed.
  ════════════════════════════════════════════════════════ -->
  <!-- ═══════════════════════════════════════════════════
    HERO — Tawaraya technique:
    Image sits at the back (Layer 1).
    Solid canvas bars overlay top + bottom (Layer 2).
    Text and nav float above everything (Layer 3).
    On scroll: bars shrink + image zooms out = cinematic reveal.
  ════════════════════════════════════════════════════════ -->
  <div id="hero-wrapper" style="height: 200svh; position: relative;">
    <div id="hero-sticky" style="position: sticky; top: 0; height: 100svh; overflow: hidden;">

      <!-- LAYER 1 — Full viewport image (behind everything)
           To swap in your photo:
           1. Put the file in /public/hero.jpg
           2. Add these two lines inside the style below:
              background-image: url('/hero.jpg');
              background-size: cover;
              background-position: center;
      -->
      <div id="hero-bg" style="
        position: absolute;
        inset: -10%;
        background-image: url('/hero.svg');
        background-size: cover;
        background-position: center;
        background-color: #090907;
        transform: scale(1.15);
        transform-origin: center;
        will-change: transform;
        z-index: 1;
      " aria-hidden="true"></div>

      <!-- Text protection vignette — ensures fonts are always readable over any photo -->
      <div aria-hidden="true" style="
        position: absolute; inset: 0; z-index: 2; pointer-events: none;
        background:
          linear-gradient(to right,  rgba(0,0,0,0.55) 0%, transparent 35%),
          linear-gradient(to bottom, rgba(0,0,0,0.4)  0%, transparent 30%),
          linear-gradient(to top,    rgba(0,0,0,0.6)  0%, transparent 45%),
          radial-gradient(ellipse 80% 60% at 50% 60%, transparent 30%, rgba(0,0,0,0.35) 100%);
      "></div>

      <!-- Grain over image -->
      <div aria-hidden="true" style="
        position: absolute; inset: 0; z-index: 3; opacity: 0.03; pointer-events: none;
        background-image: url(&quot;data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E&quot;);
        background-size: 180px;
      "></div>

      <!-- LAYER 2 — Solid bars masking top and bottom (the Tawaraya trick) -->
      <div id="hero-bar-top" style="
        position: absolute; top: 0; left: 0; right: 0;
        height: 14svh;
        background: #090907;
        z-index: 10;
        will-change: height;
        transition: background 0.6s;
      "></div>
      <div id="hero-bar-bottom" style="
        position: absolute; bottom: 0; left: 0; right: 0;
        height: 14svh;
        background: #090907;
        z-index: 10;
        will-change: height;
        transition: background 0.6s;
      "></div>

      <!-- LAYER 3 — All content floats above bars -->
      <div style="position: absolute; inset: 0; z-index: 20; pointer-events: none;">

        <!-- Top-left: site name (sits inside top bar) -->
        <a href="/" style="
          position: absolute; top: 0; left: 0;
          display: flex; align-items: center;
          height: 14svh; padding: 0 2.5rem;
          font-family: var(--font-display); font-weight: 300;
          font-size: 0.68rem; letter-spacing: 0.28em; text-transform: uppercase;
          color: rgba(255,255,255,0.5); text-decoration: none;
          transition: color 0.5s; pointer-events: auto;
        "
        onmouseover="this.style.color='rgba(255,255,255,0.9)'"
        onmouseout="this.style.color='rgba(255,255,255,0.5)'"
        >Khoi Tran</a>

        <!-- Top-right: theme toggle (inside top bar) -->
        <div style="position: absolute; top: 0; right: 0; height: 14svh; padding: 0 2.5rem; display: flex; align-items: center; pointer-events: auto;">
          <button class="theme-toggle theme-toggle-hero" data-theme-toggle aria-label="Toggle theme">
            <span data-theme-label>Light</span>
          </button>
        </div>

        <!-- Left nav — vertically centered in the image window -->
        <nav style="
          position: absolute;
          left: 2.5rem; top: 50%; transform: translateY(-50%);
          display: flex; flex-direction: column; gap: 1.75rem;
          pointer-events: auto;
        ">
          {[
            { href: '/work',    label: 'Work' },
            { href: '/writing', label: 'Writing' },
            { href: '/about',   label: 'About' },
          ].map(({ href, label }) => (
            <a href={href} style="
              font-family: var(--font-display); font-weight: 300;
              font-size: 0.72rem; letter-spacing: 0.28em; text-transform: uppercase;
              color: rgba(255,255,255,0.5); text-decoration: none; transition: color 0.5s;
            "
            onmouseover="this.style.color='rgba(255,255,255,0.92)'"
            onmouseout="this.style.color='rgba(255,255,255,0.5)'"
            >{label}</a>
          ))}
        </nav>

        <!-- Center — name and tagline in the image window -->
        <div style="
          position: absolute; inset: 0;
          display: flex; flex-direction: column;
          align-items: center; justify-content: center;
          text-align: center; padding: 14svh 2rem;
        ">
          <p style="
            font-family: var(--font-display); font-weight: 300;
            font-size: 0.65rem; letter-spacing: 0.4em; text-transform: uppercase;
            color: rgba(255,255,255,0.32); margin-bottom: 1.75rem;
          ">Student · Founder · Engineer</p>

          <h1 style="
            font-family: var(--font-display); font-weight: 300;
            font-size: clamp(3.5rem, 9vw, 8.5rem);
            line-height: 1; letter-spacing: -0.025em;
            color: rgba(255,255,255,0.92); margin-bottom: 1.75rem;
          ">Khoi Tran</h1>

          <p style="
            font-family: var(--font-body);
            font-size: clamp(0.875rem, 1.4vw, 1rem);
            line-height: 1.75; color: rgba(255,255,255,0.38); max-width: 36ch;
          ">I build things and think about building things —
          products, companies, and the ideas that hold them together.</p>
        </div>

        <!-- Scroll hint (sits inside bottom bar) -->
        <div id="hero-scroll-hint" style="
          position: absolute; bottom: 0; right: 2.5rem;
          height: 14svh; display: flex; align-items: center;
          will-change: opacity;
        ">
          <span style="
            font-family: var(--font-display); font-weight: 300;
            font-size: 0.6rem; letter-spacing: 0.3em; text-transform: uppercase;
            color: rgba(255,255,255,0.2);
          ">Scroll</span>
        </div>

      </div>
    </div>
  </div>
  <!-- End hero -->


  <!-- ═══════════════════════════════
    CONTENT — revealed after hero
  ════════════════════════════════════ -->

  <section class="section-pad" style="background: var(--color-canvas);">
    <div class="content-wrap">
      <div class="reveal" style="display:flex; align-items:baseline; justify-content:space-between; padding-bottom:1.25rem; margin-bottom:3.5rem; border-bottom:1px solid var(--color-border);">
        <span style="font-family:var(--font-display); font-weight:300; font-size:0.68rem; letter-spacing:0.3em; text-transform:uppercase; color:var(--color-muted);">Selected Work</span>
        <a href="/work" style="font-family:var(--font-display); font-weight:300; font-size:0.68rem; letter-spacing:0.22em; text-transform:uppercase; color:var(--color-accent); text-decoration:none; transition:color 0.4s;" onmouseover="this.style.color='var(--color-ink)'" onmouseout="this.style.color='var(--color-accent)'">All projects →</a>
      </div>
      {projects.length > 0 ? (
        <div>
          {projects.map((item: any, i: number) => (
            <a href={`/work/${item.slug.current}`} class="reveal row-link" style={`display:flex; align-items:baseline; justify-content:space-between; padding:1.75rem 0; border-bottom:1px solid var(--color-border); text-decoration:none; transition-delay:${i*70}ms;`}>
              <span class="row-title" style="font-family:var(--font-display); font-weight:300; font-size:clamp(1.3rem,2.8vw,2rem); color:var(--color-ink); transition:transform 0.5s cubic-bezier(0.16,1,0.3,1);">{item.title}</span>
              <span style="font-family:var(--font-display); font-weight:300; font-size:0.68rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--color-muted); display:flex; gap:2.5rem; flex-shrink:0; margin-left:2rem;"><span>{item.category}</span><span>{item.year}</span></span>
            </a>
          ))}
        </div>
      ) : (
        <p style="font-family:var(--font-display); font-weight:300; font-size:0.68rem; letter-spacing:0.25em; text-transform:uppercase; color:var(--color-muted); padding:3rem 0;">Projects coming soon.</p>
      )}
    </div>
  </section>

  <section class="section-pad" style="background: var(--color-surface);">
    <div class="content-wrap">
      <div class="reveal" style="display:flex; align-items:baseline; justify-content:space-between; padding-bottom:1.25rem; margin-bottom:3.5rem; border-bottom:1px solid var(--color-border);">
        <span style="font-family:var(--font-display); font-weight:300; font-size:0.68rem; letter-spacing:0.3em; text-transform:uppercase; color:var(--color-muted);">Writing</span>
        <a href="/writing" style="font-family:var(--font-display); font-weight:300; font-size:0.68rem; letter-spacing:0.22em; text-transform:uppercase; color:var(--color-accent); text-decoration:none; transition:color 0.4s;" onmouseover="this.style.color='var(--color-ink)'" onmouseout="this.style.color='var(--color-accent)'">All posts →</a>
      </div>
      {posts.length > 0 ? (
        <div>
          {posts.map((post: any, i: number) => (
            <a href={`/writing/${post.slug.current}`} class="reveal row-link" style={`display:flex; align-items:baseline; justify-content:space-between; padding:1.75rem 0; border-bottom:1px solid var(--color-border); text-decoration:none; transition-delay:${i*70}ms;`}>
              <span class="row-title" style="font-family:var(--font-display); font-weight:300; font-size:clamp(1rem,2.2vw,1.55rem); color:var(--color-ink); max-width:58%; transition:transform 0.5s cubic-bezier(0.16,1,0.3,1);">{post.title}</span>
              <span style="font-family:var(--font-display); font-weight:300; font-size:0.68rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--color-muted); display:flex; gap:2.5rem; flex-shrink:0; margin-left:2rem;"><span>{post.category}</span><span>{formatDate(post.publishedAt)}</span></span>
            </a>
          ))}
        </div>
      ) : (
        <p style="font-family:var(--font-display); font-weight:300; font-size:0.68rem; letter-spacing:0.25em; text-transform:uppercase; color:var(--color-muted); padding:3rem 0;">Writing coming soon.</p>
      )}
    </div>
  </section>

  <section class="section-pad" style="background: var(--color-canvas);">
    <div class="content-wrap grid-2col">
      <div class="reveal">
        <p style="font-family:var(--font-display); font-weight:300; font-size:0.68rem; letter-spacing:0.3em; text-transform:uppercase; color:var(--color-muted); margin-bottom:2.5rem;">About</p>
        <p style="font-family:var(--font-body); font-size:1.1rem; color:var(--color-ink-soft); line-height:1.85; margin-bottom:1.25rem;">I'm a student and founder based in Texas, building at the intersection of technology and product.</p>
        <p style="font-family:var(--font-body); font-size:0.95rem; color:var(--color-muted); line-height:1.85; margin-bottom:3rem;">I care about the craft of making — code that's clean, products that are clear, and ideas that have earned their place.</p>
        <a href="/about" style="font-family:var(--font-display); font-weight:300; font-size:0.68rem; letter-spacing:0.22em; text-transform:uppercase; color:var(--color-accent); text-decoration:none;">More about me →</a>
      </div>
      <div class="reveal" style="transition-delay:120ms;">
        <p style="font-family:var(--font-display); font-weight:300; font-size:0.68rem; letter-spacing:0.3em; text-transform:uppercase; color:var(--color-muted); margin-bottom:2.5rem;">Now</p>
        <p style="font-family:var(--font-body); font-size:0.95rem; color:var(--color-muted); line-height:1.85; margin-bottom:3rem;">Currently focused on building products, writing more, and figuring out what it means to start something from scratch.</p>
        <a href="/now" style="font-family:var(--font-display); font-weight:300; font-size:0.68rem; letter-spacing:0.22em; text-transform:uppercase; color:var(--color-accent); text-decoration:none;">What I'm doing now →</a>
      </div>
    </div>
  </section>

  <footer style="border-top:1px solid var(--color-border);">
    <div style="max-width:1100px; margin:0 auto; padding:2.5rem 3rem; display:flex; align-items:center; justify-content:space-between;">
      <p style="font-family:var(--font-display); font-weight:300; font-size:0.65rem; letter-spacing:0.2em; text-transform:uppercase; color:var(--color-muted);">© {new Date().getFullYear()} Khoi Tran</p>
      <div style="display:flex; gap:2.5rem;">
        {[['https://github.com/khoitrn','GitHub'],['https://linkedin.com/in/khoitrn','LinkedIn'],['mailto:khoi@tamu.edu','Email']].map(([href,label]) => (
          <a href={href} target={href.startsWith('http')?'_blank':undefined} rel={href.startsWith('http')?'noopener noreferrer':undefined} style="font-family:var(--font-display); font-weight:300; font-size:0.65rem; letter-spacing:0.2em; text-transform:uppercase; color:var(--color-muted); text-decoration:none; transition:color 0.4s;" onmouseover="this.style.color='var(--color-ink)'" onmouseout="this.style.color='var(--color-muted)'">{label}</a>
        ))}
      </div>
    </div>
  </footer>

</Layout>

<style>
  .row-link:hover .row-title { transform: translateX(10px); }
</style>

<script>
  import Lenis from 'lenis';

  const bg         = document.getElementById('hero-bg') as HTMLElement;
  const barTop     = document.getElementById('hero-bar-top') as HTMLElement;
  const barBot     = document.getElementById('hero-bar-bottom') as HTMLElement;
  const scrollHint = document.getElementById('hero-scroll-hint') as HTMLElement;

  if (bg && barTop && barBot) {
    const lerp = (a: number, b: number, t: number) => a + (b - a) * t;
    let cur = 0;

    function update() {
      const raw = Math.max(0, Math.min(window.scrollY / window.innerHeight, 1));
      cur = lerp(cur, raw, 0.09);
      const p = cur;

      // Bars: shrink from 14svh → 7svh (narrower letterbox as image opens up)
      const barH = lerp(14, 7, p);
      barTop.style.height = `${barH}svh`;
      barBot.style.height = `${barH}svh`;

      // Image: zoom out from 1.15 → 1.0
      bg.style.transform = `scale(${lerp(1.15, 1.0, p)})`;

      // Sync bar color with theme
      const canvasBg = getComputedStyle(document.documentElement).getPropertyValue('--color-canvas').trim();
      barTop.style.background = canvasBg;
      barBot.style.background = canvasBg;

      // Scroll hint fades out
      if (scrollHint) scrollHint.style.opacity = Math.max(0, 1 - p * 5).toString();

      requestAnimationFrame(update);
    }

    requestAnimationFrame(update);
  }
</script>
