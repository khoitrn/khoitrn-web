---
import Layout from '../layouts/Layout.astro';
import { client, nowQuery, portableTextToHtml, formatDate } from '../lib/sanity';

const now = await client.fetch(nowQuery);
const html = now ? portableTextToHtml(now.body ?? []) : null;
const updated = now?.updatedAt ? formatDate(now.updatedAt) : null;
---

<Layout title="Now" description="What Khoi is currently working on.">
  <div class="pt-40 pb-32 px-6 md:px-12">
    <div class="max-w-2xl mx-auto">

      <div class="mb-16 pb-8 border-b border-[var(--color-border)]">
        <p class="animate-fade-up font-display font-light text-xs tracking-[0.3em] uppercase text-[var(--color-muted)] mb-6">Now</p>
        <h1 class="animate-fade-up animate-fade-up-delay-1 font-display font-light text-4xl md:text-5xl leading-[1.1] tracking-[-0.02em] text-[var(--color-ink)]">
          What I'm doing now.
        </h1>
        {updated && (
          <p class="animate-fade-up animate-fade-up-delay-2 font-display font-light text-xs tracking-[0.2em] uppercase text-[var(--color-muted)] mt-6">
            Updated {updated}
          </p>
        )}
      </div>

      {html ? (
        <div class="reveal prose" set:html={html} />
      ) : (
        <div class="reveal prose">
          <p>Updated April 2025 from Texas.</p>
          <h2>Building</h2>
          <p>Working on a new project — still in early days, focused on getting the core right before anything else.</p>
          <h2>Studying</h2>
          <p>Finishing up the semester at Texas A&M. Juggling coursework with building, which is harder than it sounds and more valuable than it seems.</p>
          <h2>Thinking about</h2>
          <p>What makes a product actually good. The gap between clever and useful. How to build something worth building.</p>
          <hr />
          <p>This is a <a href="https://nownownow.com/about" target="_blank" rel="noopener">now page</a> — a snapshot of what I'm focused on at this point in time.</p>
        </div>
      )}

    </div>
  </div>
</Layout>
