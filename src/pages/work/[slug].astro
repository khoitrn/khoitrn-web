---
import Layout from '../../layouts/Layout.astro';
import { client, projectsQuery, projectBySlugQuery, portableTextToHtml, urlFor } from '../../lib/sanity';

export async function getStaticPaths() {
  const projects = await client.fetch(projectsQuery);
  return projects.map((project: any) => ({
    params: { slug: project.slug.current },
  }));
}

const { slug } = Astro.params;
const project = await client.fetch(projectBySlugQuery, { slug });

if (!project) return Astro.redirect('/work');

const html = portableTextToHtml(project.body ?? []);
const coverUrl = project.coverImage ? urlFor(project.coverImage).width(1600).auto('format').url() : null;
---

<Layout title={project.title} description={project.description}>
  <div class="pt-40 pb-32 px-6 md:px-12">
    <div class="max-w-5xl mx-auto">

      <!-- Header -->
      <div class="mb-16 pb-8 border-b border-[var(--color-border)]">
        <a href="/work" class="animate-fade-up font-display font-light text-xs tracking-[0.2em] uppercase text-[var(--color-muted)] hover:text-[var(--color-ink)] transition-colors duration-300 inline-block mb-10">
          ← Work
        </a>
        <div class="animate-fade-up animate-fade-up-delay-1 flex items-center gap-6 mb-6">
          {project.category && <span class="font-display font-light text-xs tracking-[0.2em] uppercase text-[var(--color-muted)]">{project.category}</span>}
          {project.year && (
            <>
              <span class="text-[var(--color-border)]">·</span>
              <span class="font-display font-light text-xs tracking-[0.2em] uppercase text-[var(--color-muted)]">{project.year}</span>
            </>
          )}
        </div>
        <h1 class="animate-fade-up animate-fade-up-delay-2 font-display font-light leading-[1.1] tracking-[-0.02em] text-[var(--color-ink)]" style="font-size: clamp(2rem, 5vw, 3.5rem);">
          {project.title}
        </h1>
        {project.description && (
          <p class="animate-fade-up animate-fade-up-delay-3 font-body text-lg text-[var(--color-muted)] leading-relaxed mt-6 max-w-2xl">
            {project.description}
          </p>
        )}

        <div class="flex flex-wrap items-center gap-6 mt-8">
          {project.technologies?.map((tech: string) => (
            <span class="font-display font-light text-xs tracking-[0.15em] uppercase text-[var(--color-muted)] border border-[var(--color-border)] px-3 py-1">{tech}</span>
          ))}
          {project.url && (
            <a href={project.url} target="_blank" rel="noopener noreferrer" class="font-display font-light text-xs tracking-[0.2em] uppercase text-[var(--color-accent)] hover:text-[var(--color-ink)] transition-colors duration-300 ml-auto">
              Visit project →
            </a>
          )}
        </div>
      </div>

      <!-- Cover image -->
      {coverUrl && (
        <div class="reveal mb-16 aspect-video overflow-hidden bg-[var(--color-surface)]">
          <img src={coverUrl} alt={project.title} class="w-full h-full object-cover" loading="lazy" />
        </div>
      )}

      <!-- Body -->
      {html && (
        <div class="reveal prose mx-auto" set:html={html} />
      )}

    </div>
  </div>
</Layout>
