---
import Layout from '../../layouts/Layout.astro';
import { client, projectsQuery } from '../../lib/sanity';

const projects = await client.fetch(projectsQuery);
---

<Layout title="Work" description="Selected projects in product, engineering, and startups.">
  <div style="padding-top:8rem; padding-bottom:8rem;">

    <div style="max-width:1100px; margin:0 auto; padding:0 3rem 5rem; border-bottom:1px solid var(--color-border);">
      <a href="/" style="font-family:var(--font-display); font-weight:300; font-size:0.65rem; letter-spacing:0.25em; text-transform:uppercase; color:var(--color-muted); text-decoration:none; display:inline-block; margin-bottom:3rem; transition:color 0.4s;" onmouseover="this.style.color='var(--color-ink)'" onmouseout="this.style.color='var(--color-muted)'">← Home</a>
      <p class="animate-fade-up" style="font-family:var(--font-display); font-weight:300; font-size:0.68rem; letter-spacing:0.3em; text-transform:uppercase; color:var(--color-muted); margin-bottom:1.5rem;">Work</p>
      <h1 class="animate-fade-up delay-1" style="font-family:var(--font-display); font-weight:300; font-size:clamp(2.5rem,6vw,4.5rem); line-height:1.1; letter-spacing:-0.02em; color:var(--color-ink);">Selected projects.</h1>
    </div>

    <div style="max-width:1100px; margin:0 auto; padding:4rem 3rem 0;">
      {projects.length > 0 ? (
        <div>
          {projects.map((project: any, i: number) => (
            <a href={`/work/${project.slug.current}`} class="reveal project-row" style={`display:flex; align-items:baseline; justify-content:space-between; padding:2rem 0; border-bottom:1px solid var(--color-border); text-decoration:none; transition-delay:${i*60}ms;`}>
              <div style="flex:1;">
                <p style="font-family:var(--font-display); font-weight:300; font-size:0.65rem; letter-spacing:0.22em; text-transform:uppercase; color:var(--color-muted); margin-bottom:0.75rem;">{project.category} · {project.year}</p>
                <h2 class="project-title" style="font-family:var(--font-display); font-weight:300; font-size:clamp(1.5rem,3vw,2.5rem); color:var(--color-ink); margin-bottom:0.75rem; transition:transform 0.5s cubic-bezier(0.16,1,0.3,1);">{project.title}</h2>
                {project.description && <p style="font-family:var(--font-body); font-size:0.9rem; color:var(--color-muted); line-height:1.7; max-width:52ch;">{project.description}</p>}
              </div>
              <span style="font-family:var(--font-display); font-weight:300; font-size:0.65rem; letter-spacing:0.22em; text-transform:uppercase; color:var(--color-accent); flex-shrink:0; margin-left:2rem; transition:color 0.4s;">View →</span>
            </a>
          ))}
        </div>
      ) : (
        <p style="font-family:var(--font-display); font-weight:300; font-size:0.68rem; letter-spacing:0.25em; text-transform:uppercase; color:var(--color-muted); padding:4rem 0;">Projects coming soon.</p>
      )}
    </div>
  </div>
</Layout>

<style>
  .project-row:hover .project-title { transform: translateX(8px); }
  .project-row:hover span[style*="color:accent"] { color: var(--color-ink) !important; }
</style>
