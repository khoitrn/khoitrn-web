---
import Layout from '../../layouts/Layout.astro';
import { client, projectsQuery } from '../../lib/sanity';

const projects = await client.fetch(projectsQuery);
---

<Layout title="Work" description="Selected projects in product, engineering, and startups.">
  <div class="pt-40 pb-32 px-6 md:px-12">
    <div class="max-w-5xl mx-auto">

      <div class="mb-24 pb-8 border-b border-[var(--color-border)]">
        <p class="animate-fade-up font-display font-light text-xs tracking-[0.3em] uppercase text-[var(--color-muted)] mb-6">Work</p>
        <h1 class="animate-fade-up animate-fade-up-delay-1 font-display font-light leading-[1.1] tracking-[-0.02em] text-[var(--color-ink)]" style="font-size: clamp(2.5rem, 6vw, 4.5rem);">
          Selected projects.
        </h1>
      </div>

      {projects.length > 0 ? (
        <div>
          {projects.map((project: any) => (
            <a href={`/work/${project.slug.current}`} class="reveal group flex flex-col md:flex-row md:items-baseline gap-4 md:gap-0 py-8 border-b border-[var(--color-border)] hover:border-[var(--color-ink)] transition-all duration-300">
              <div class="flex-1">
                <p class="font-display font-light text-xs tracking-[0.2em] uppercase text-[var(--color-muted)] mb-3">{project.category} · {project.year}</p>
                <h2 class="font-display font-light text-2xl md:text-3xl text-[var(--color-ink)] mb-3 group-hover:translate-x-2 transition-transform duration-300 ease-out">{project.title}</h2>
                {project.description && <p class="font-body text-sm text-[var(--color-muted)] leading-relaxed max-w-lg">{project.description}</p>}
              </div>
              <span class="font-display font-light text-xs tracking-[0.2em] uppercase text-[var(--color-accent)] group-hover:text-[var(--color-ink)] transition-colors duration-300 shrink-0">View →</span>
            </a>
          ))}
        </div>
      ) : (
        <div class="py-24 text-center">
          <p class="font-display font-light text-xs tracking-[0.3em] uppercase text-[var(--color-muted)]">Projects coming soon.</p>
        </div>
      )}

    </div>
  </div>
</Layout>
