---
import Layout from '../../layouts/Layout.astro';
import { client, postsQuery, formatDate } from '../../lib/sanity';

const posts = await client.fetch(postsQuery);
---

<Layout title="Writing" description="Essays on products, startups, and engineering.">
  <div class="pt-40 pb-32 px-6 md:px-12">
    <div class="max-w-5xl mx-auto">

      <div class="mb-24 pb-8 border-b border-[var(--color-border)]">
        <p class="animate-fade-up font-display font-light text-xs tracking-[0.3em] uppercase text-[var(--color-muted)] mb-6">Writing</p>
        <h1 class="animate-fade-up animate-fade-up-delay-1 font-display font-light leading-[1.1] tracking-[-0.02em] text-[var(--color-ink)]" style="font-size: clamp(2.5rem, 6vw, 4.5rem);">
          Essays, notes,<br />and thinking.
        </h1>
      </div>

      {posts.length > 0 ? (
        <div>
          {posts.map((post: any) => (
            <a href={`/writing/${post.slug.current}`} class="reveal group grid md:grid-cols-[1fr_auto] gap-4 py-8 border-b border-[var(--color-border)] hover:border-[var(--color-ink)] transition-all duration-300">
              <div>
                <p class="font-display font-light text-xs tracking-[0.2em] uppercase text-[var(--color-muted)] mb-3">{post.category}</p>
                <h2 class="font-display font-light text-xl md:text-2xl text-[var(--color-ink)] mb-3 group-hover:translate-x-2 transition-transform duration-300 ease-out">{post.title}</h2>
                {post.excerpt && <p class="font-body text-sm text-[var(--color-muted)] leading-relaxed max-w-lg">{post.excerpt}</p>}
              </div>
              <div class="font-display font-light text-xs tracking-[0.15em] uppercase text-[var(--color-muted)] md:text-right self-start mt-1 shrink-0">
                {formatDate(post.publishedAt)}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="py-24 text-center">
          <p class="font-display font-light text-xs tracking-[0.3em] uppercase text-[var(--color-muted)]">Writing coming soon.</p>
        </div>
      )}

    </div>
  </div>
</Layout>
